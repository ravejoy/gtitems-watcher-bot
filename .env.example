# Telegram
BOT_TOKEN=                     # your Telegram bot token
WEBHOOK_SECRET=supersecret     # random string, used to verify webhook calls

# Redis (Upstash REST API)
UPSTASH_REDIS_REST_URL=        # e.g. https://eu1-youproject.upstash.io
UPSTASH_REDIS_REST_TOKEN=      # token from Upstash console

# Bot defaults
DEFAULT_PAGES=20               # how many pages to scan by default for new users
BASE_URL=https://rpgtop.su     # base site url
SCAN_COMM_PATH=/comm/26742     # relative path to a review page

# Optional (for setWebhook or local testing)
APP_PUBLIC_URL=https://your-vercel-app.vercel.app
